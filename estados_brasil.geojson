def criar_mapa_coropletico(df_mapa, geojson):
    """Cria o mapa coroplético usando GeoJSON com layout otimizado"""
    if df_mapa.empty or geojson is None:
        return None
    
    # Criar o mapa choropleth com GeoJSON
    fig = px.choropleth(
        df_mapa,
        geojson=geojson,
        locations='sigla',
        color='sincronismos',
        featureidkey='properties.sigla',
        hover_name='estado',
        hover_data={
            'empresa_nome': True,
            'sincronismos': True,
            'regiao': True,
            'sigla': False
        },
        color_continuous_scale='Reds',
        title="<b>Mapa de Sincronizações por Estado</b>",
        labels={'sincronismos': 'Nº de Sincronizações'}
    )
    
    # Ajustar a projeção e o centro do mapa para o Brasil
    fig.update_geos(
        projection_type="mercator",
        center=dict(lon=-55, lat=-15),
        projection_scale=3.2,
        visible=True,
        showcountries=True,
        countrycolor='rgba(0,0,0,0.3)',
        showsubunits=True,
        subunitcolor='rgba(0,0,0,0.2)',
        showcoastlines=True,
        coastlinecolor='rgba(0,0,0,0.3)',
        showland=True,
        landcolor='rgb(245, 245, 245)',
        showocean=True,
        oceancolor='rgba(200, 220, 240, 0.5)'
    )
    
    # Configurar o layout
    fig.update_layout(
        height=650,
        margin={"r": 10, "t": 50, "l": 10, "b": 10},
        coloraxis_colorbar=dict(
            title="Sincronizações",
            thicknessmode="pixels",
            thickness=25,
            lenmode="pixels",
            len=350,
            yanchor="middle",
            y=0.5,
            title_font=dict(size=12, color=COR_AZUL_ESCURO),
            tickfont=dict(size=10)
        ),
        title_font=dict(size=14, color=COR_AZUL_ESCURO)
    )
    
    return fig
